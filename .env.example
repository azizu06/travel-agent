# All server-only. Copy to .env.local and fill in real values.

# OpenAI — text plan (Vercel AI SDK) + destination image (gpt-image-1)
OPENAI_API_KEY=

# OpenWeatherMap — geocoding + 5-day forecast
WEATHER_API_KEY=

# Vercel Blob — stores the generated destination image
BLOB_READ_WRITE_TOKEN=

# Upstash Redis — stores the trip (travel:<id>) and backs IP rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
